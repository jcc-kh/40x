# World ID (from https://developer.world.org)
NEXT_PUBLIC_WORLD_APP_ID=app_xxxxxxxxxxxxxxxxxxxxxxxx
WORLD_RP_ID=rp_xxxxxxxxxxxxxxxxxxxxxxxx
RP_SIGNING_KEY=0x...

# ENS — set chain ID to 1 (mainnet) or 11155111 (Sepolia)
NEXT_PUBLIC_ENS_CHAIN_ID=11155111
NEXT_PUBLIC_ALCHEMY_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# WalletConnect (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_wc_project_id

# Chainlink Confidential AI Attester (API key from Chainlink desk)
CHAINLINK_ATTESTER_URL=https://confidential-ai-dev-preview.cldev.cloud
INFERENCE_API_KEY=your_inference_api_key_here
# Public URL for Attester cre_callback (ngrok to CRE :2000/trigger or Next.js /api/attester/callback)
CRE_CALLBACK_URL=https://your-ngrok-url.ngrok-free.dev/trigger
# Optional: forward Attester callbacks to local CRE trigger for on-chain write
CRE_TRIGGER_FORWARD_URL=http://localhost:2000/trigger

# CRE workflow (local simulate)
CRE_WORKFLOW_PATH=./cre-workflow
CRE_CLI_PATH=cre
CRE_ETH_PRIVATE_KEY=0x...

# On-chain consumer (deploy TenantCredentialGate.sol to Sepolia)
NEXT_PUBLIC_TENANT_CREDENTIAL_GATE_ADDRESS=0x...
