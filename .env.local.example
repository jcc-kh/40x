# World ID (from https://developer.world.org)
NEXT_PUBLIC_WORLD_APP_ID=app_xxxxxxxxxxxxxxxxxxxxxxxx
WORLD_RP_ID=rp_xxxxxxxxxxxxxxxxxxxxxxxx
RP_SIGNING_KEY=0x...

# ENS — set chain ID to 1 (mainnet) or 11155111 (Sepolia)
NEXT_PUBLIC_ENS_CHAIN_ID=11155111
NEXT_PUBLIC_ALCHEMY_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# WalletConnect (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_wc_project_id

# CRE workflow simulation
CRE_WORKFLOW_PATH=./cre-workflow
CRE_CLI_PATH=cre

# Gemini API key lives in cre-workflow/.env as GEMINI_API_KEY_ENV
